<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>

<IfModule mod_php.c>
    php_value upload_max_filesize 50M
    php_value post_max_size 50M
</IfModule>

<IfModule lsapi_module>
    php_value upload_max_filesize 50M
    php_value post_max_size 50M
</IfModule>
